---

<section id="projects">
  <div class="section-heading">
    <div>
      <h2>Projets</h2>
      <p class="section-text">
        Voici une sélection de projets réalisés durant ma formation, mes exercices
        pratiques et mes mises en situation de développement web.
      </p>
    </div>

    <a
      href="https://github.com/fabien7513"
      target="_blank"
      rel="noopener noreferrer"
      class="button button-secondary"
    >
      Voir mon GitHub
    </a>
  </div>

  <article class="featured-project js-tilt-card" data-tilt-strength="4">
    <div class="featured-project-media">
      <img src={featuredProject.image} alt={featuredProject.alt} />
    </div>

    <div class="featured-project-content">
      <p class="featured-project-eyebrow">{featuredProject.eyebrow}</p>
      <h3>{featuredProject.title}</h3>
      <p>{featuredProject.summary}</p>
      <p><strong>Ce que j’y ai travaillé :</strong> {featuredProject.role}</p>

      <ul class="featured-project-list">
        {featuredProject.highlights.map((highlight) => (
          <li>{highlight}</li>
        ))}
      </ul>
    </div>
  </article>

  <div class="projects-grid">
    {projects.map((project) => (
      <article class="project-card js-tilt-card" data-tilt-strength="5">
        <div class="project-card-depth project-depth-back"></div>
        <div class="project-card-depth project-depth-front"></div>

        <div class="project-visual">
          <img src={project.image} alt={project.alt} />
        </div>

        <div class="project-content">
          <div class="project-top">
            <span class="project-badge">{project.badge}</span>
            <h3>{project.title}</h3>
          </div>

          <p>{project.description}</p>

          <p><strong>Technologies :</strong> {project.technologies}</p>

          <div class="project-actions">
            <button
              type="button"
              class="button button-primary open-modal"
              data-title={project.title}
              data-description={project.description}
              data-image={project.image}
              aria-controls="modal"
              aria-haspopup="dialog"
            >
              Voir plus
            </button>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<div id="modal" class="modal" aria-hidden="true">
  <div
    class="modal-content"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
    aria-describedby="modal-description"
    tabindex="-1"
  >
    <button class="close-modal" type="button" aria-label="Fermer la fenêtre">
      &times;
    </button>

    <img id="modal-image" src="" alt="" hidden />

    <h3 id="modal-title"></h3>
    <p id="modal-description"></p>
  </div>
</div>
